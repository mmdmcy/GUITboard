ID=build-host
TITLE=Build Local Binary
DESCRIPTION=Build an optional local binary for the current host into dist/.
TIMEOUT_SECONDS=1800
CWD={{repo}}
POSIX_PROGRAM=sh
POSIX_ARGS=-c|mkdir -p dist && exec go build -o dist/GUITboard ./cmd/guitboard
WINDOWS_PROGRAM=cmd
WINDOWS_ARGS=/c|if not exist dist mkdir dist && go build -o dist\\GUITboard.exe .\\cmd\\guitboard
